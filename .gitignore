logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
temp/
tmp/

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Optional local overrides
*.local
